# ==========================================================
# SangSePage - Environment Variables
# ==========================================================
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요.
# .env.local은 절대 GitHub에 커밋되지 않습니다.

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- AI Providers ----------
OPENAI_API_KEY=sk-proj-...

# Gemini API 키 (아래 3가지 방법 중 하나 이상 사용, 다중 키 권장)
# 여러 키를 설정하면 크레딧 소진(429) / 인증 오류(401/403) 시 자동 페일오버됨
#
# 방법 1: 단일 키 (기존 방식, 하위 호환)
GEMINI_API_KEY=AIzaSy...primary

# 방법 2: 쉼표로 구분된 다중 키
# GEMINI_API_KEYS=AIzaSy...key1,AIzaSy...key2,AIzaSy...key3

# 방법 3: 번호 접미사 방식 (1~20까지 지원)
# GEMINI_API_KEY_1=AIzaSy...backup1
# GEMINI_API_KEY_2=AIzaSy...backup2
# GEMINI_API_KEY_3=AIzaSy...backup3

# ---------- Cloudflare Turnstile (봇 차단) ----------
# 회원가입 폼의 CAPTCHA - https://dash.cloudflare.com/?to=/:account/turnstile 에서 발급
# 미설정 시 Turnstile 검증이 자동으로 우회됨 (로컬 개발 편의)
# 프로덕션에서는 반드시 설정 필요
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAA...
TURNSTILE_SECRET_KEY=0x4AAA...secret

# ---------- Payment (선택) ----------
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ---------- Deployment ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
